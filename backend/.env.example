# ===========================================
# Chain Menu Hub — Backend Environment Variables
# ===========================================
# Kopyala: cp .env.example .env
# Ardından gerçek değerleri yaz.
# ===========================================

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# --- Upstash Redis ---
UPSTASH_REDIS_URL=https://<endpoint>.upstash.io
UPSTASH_REDIS_TOKEN=<upstash-redis-token>

# --- CORS ---
# Virgülle ayrılmış origin listesi. Geliştirme için "*" kullanılabilir.
CORS_ORIGINS=*
